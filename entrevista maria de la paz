    flex: 1;
    height: 100%;
    overflow-y: auto;
    padding: 40px;
    background-color: #c2c2c2;
}

.gallery-mobile {
    display: none;
}

        /* 3. ESTILOS DE CONTENIDO */
        .text-content {
            max-width: 550px;
            margin: 0 auto;
            line-height: 1.6;
            font-size: 14px;
            text-align: justify;
        }

        .text-content h1 {
            font-size: 18px;
            margin-bottom: 5px;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

 .text-content h2 {
    font-size: 21px;
    font-weight: bold;
    font-style: italic;
    margin-bottom: 15px;
    line-height: 1.2;
}
.article-meta-top {
    margin-bottom: 20px;
    font-size: 14px;
    color: #000;
}

        .references {
            margin-top: 60px;
            font-size: 11px;
            color: #666;
            
            padding-top: 20px;
        }

        /* 4. GRID DE ARE.NA */
        #arena-container {
            display: grid;
            grid-template-columns: 1fr 1fr; /* 2 fotos por fila dentro de la columna */
            gap: 20px;
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .work-item {
            display: flex;
            flex-direction: column;
            cursor: pointer;
        }

        .work-item img {
            width: 100%;
            height: auto;
            display: block;
            transition: opacity 0.3s ease;
        }

        .work-item img:hover {
            opacity: 0.8;
        }

        .caption {
            font-size: 10px;
            margin-top: 8px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* 5. RESPONSIVE (A partir de tablets/móviles se apilan) */

@media (max-width: 900px) {
    body, html {
        overflow: visible !important;
        height: auto;
    }

    main {
        display: block;
        height: auto;
        overflow: visible;
        margin-top: 60px;
    }

    .text-column, .gallery-column {
        height: auto;
        overflow: visible;
        flex: none;
        width: 100%;
        padding: 40px 16px;
    }

    .gallery-column {
        display: none;
    }

    .gallery-mobile {
        display: block;
        width: 100%;
        margin: 32px auto;
    }

    .gallery-mobile ul {
        width: 100%;
        margin: 0 auto;
        padding: 0;
    }

    .gallery-mobile .work-item {
        margin: 0 auto;
    }

    #arena-container {
        grid-template-columns: 1fr;
    }
}

        /* 6. VISOR FULLSCREEN */
