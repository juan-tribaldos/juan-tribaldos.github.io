    <script>
        $(function() {
            // Verifica que este slug sea idéntico al de tu URL en Are.na
            const CHANNEL_SLUG = 'fiorella-resenterra'; 
            const API_BASE = 'https://api.are.na/v2';

            async function fetchArenaBlocks() {
                try {
                    const response = await fetch(`${API_BASE}/channels/${CHANNEL_SLUG}/contents?per=100&direction=desc`, {
                        headers: { 'Authorization': 'Bearer MK79DychUcC3cqHY1dryGEOQjnCM4frc05tzFRZGcPU' }
                    });
                    if (!response.ok) throw new Error("Canal no encontrado");
                    const data = await response.json();
                    return data.contents.filter(block => block.class === 'Image');
                } catch (error) {
                    console.error("Error cargando Are.na:", error);
                    return [];
                }
            }

    async function init() {
    const blocks = await fetchArenaBlocks();
    const $desktopContainer = $('#arena-container');
    const $mobile1 = $('#arena-mobile-1');
    const $mobile2 = $('#arena-mobile-2');
    const $mobile3 = $('#arena-mobile-3');
    const $mobile4 = $('#arena-mobile-4');
    const $mobile5 = $('#arena-mobile-5');
    const $mobile6 = $('#arena-mobile-6');

    if (blocks.length === 0) {
        $desktopContainer.append('<p>No se pudieron cargar imágenes. Revisa el slug del canal.</p>');
        return;
    }

    blocks.forEach((block, index) => {
        const imageUrl = block.image.original.url;
        const title = block.title || "";
        
        const html = `
            <li class="work-item">
                <img src="${imageUrl}" alt="${title}" loading="lazy" />
                <div class="caption">
                    <div>${title}</div>
                </div>
            </li>`;
        
        const $newItem = $(html);

        $desktopContainer.append($newItem);

        $newItem.on('click', function() {
            $('#fullscreen-viewer')
                .html(`<img src="${imageUrl}">`)
                .css('display', 'flex');

            utrack('image_fullscreen', {
                page: 'salita-2025',
                title: title
            });
        });

        const $mobileItem = $newItem.clone(true);

        if (index < 3) {
    $mobile1.append($mobileItem);
}
else if (index < 6) {
    $mobile2.append($mobileItem);
}
else if (index < 9) {
    $mobile3.append($mobileItem);
}
else if (index < 12) {
    $mobile4.append($mobileItem);
}
else if (index < 15) {
    $mobile5.append($mobileItem);
}
else {
    $mobile6.append($mobileItem);
}
    });
}

$('#fullscreen-viewer').on('click', function() { 
    $(this).hide().empty(); 
});

init();
});
</script>
