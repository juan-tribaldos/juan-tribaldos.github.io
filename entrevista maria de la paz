            display: flex; 
            flex-direction: row; /* Fuerza la disposición en horizontal */
            height: calc(100vh - 60px); /* Altura total menos el nav */
            margin-top: 60px; /* Espacio para el nav fijo */
            width: 100%;
            overflow: hidden;
        }

        /* Columna Izquierda: Texto */
