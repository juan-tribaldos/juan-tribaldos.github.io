        /* 1. RESET Y ESTRUCTURA BASE */
        * {
            box-sizing: border-box;
        }

        body, html {
            margin: 0;
            padding: 0;
            height: 100%;
            width: 100%;
            overflow: hidden; /* Evita el scroll global de la ventana */
            
        }

        /* 2. LAYOUT DE COLUMNAS */
